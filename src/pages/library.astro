---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CimLibraryNav from '../components/CimLibraryNav.astro';
import ContentTag from '../components/ContentTag.astro';
import TaxonomyAtlas from '../components/TaxonomyAtlas.astro';
import taxonomy from '../data/taxonomy.json';

const entries = await getCollection('papers');
const papers = entries
  .map((entry) => ({ id: entry.id, ...entry.data }))
  .sort((a, b) => a.title.localeCompare(b.title));
---
<BaseLayout title="CIM Compiler/IR Paper Library">
  <CimLibraryNav />
  <ContentTag />
  <header class="wrap page-header library-page-header">
    <p class="eyebrow eyebrow--dark">CIM compiler/IR corpus</p>
    <h1>Paper Library Taxonomy Atlas</h1>
    <p>A static, Markdown-backed atlas for paper notes classified by stack role, middle-layer abstraction, first-class CIM objects, and rewrite object.</p>
  </header>
  <main class="wrap atlas-wrap atlas-page-layout">
    <nav class="section-nav atlas-section-nav" aria-label="Atlas page sections">
      <div class="section-nav-title">Atlas Sections</div>
      <div class="outline-stack">
        <div class="outline-section outline-leaf"><a href="#atlas-section">Interactive atlas</a></div>
        <div class="outline-section outline-leaf"><a href="#taxonomy">Taxonomy axes</a></div>
      </div>
    </nav>
    <div class="atlas-page-content">
      <TaxonomyAtlas papers={papers} taxonomy={taxonomy} />
    </div>
  </main>
  <footer class="wrap footer">Static Astro draft. Paper metadata comes from Markdown frontmatter in <code>src/content/papers</code>.</footer>
</BaseLayout>
