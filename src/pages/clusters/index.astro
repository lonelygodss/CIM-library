---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CimLibraryNav from '../../components/CimLibraryNav.astro';
import clustersData from '../../data/clusters.json';
import profile from '../../data/profile.json';
import taxonomy from '../../data/taxonomy.json';

type ClusterQuery = {
  layout?: string;
  q?: string;
  a?: string;
  b?: string;
  c?: string;
  d?: string;
  tech?: string;
  workload?: string;
  paper?: string;
};

type PaperSummary = {
  slug: string;
  title: string;
  year?: number | null;
  venue?: string | null;
  authors_or_group?: string | null;
  summary: string;
  route: string;
  axis_A: {
    primary: keyof typeof taxonomy.families;
    secondary?: Array<keyof typeof taxonomy.families>;
  };
  axis_B: Array<keyof typeof taxonomy.middles>;
  technology: string[];
  workloads: string[];
};

const entries = await getCollection('papers');
const papersBySlug = new Map<string, PaperSummary>(
  entries.map((entry) => [
    entry.data.slug,
    {
      ...entry.data,
      route: `/papers/${entry.data.slug}/`
    }
  ])
);

const missingSlugs = clustersData.clusters.flatMap((cluster) => [
  ...cluster.representative_papers,
  ...cluster.supporting_papers,
  ...cluster.working_groups.flatMap((group) => group.representative_papers)
]).filter((slug) => !papersBySlug.has(slug));

if (missingSlugs.length) {
  throw new Error(`Cluster data references missing paper slug(s): ${[...new Set(missingSlugs)].join(', ')}`);
}

const uniqueClusterPapers = new Set(
  clustersData.clusters.flatMap((cluster) => [...cluster.representative_papers, ...cluster.supporting_papers])
);
const workingGroupCount = clustersData.clusters.reduce((sum, cluster) => sum + cluster.working_groups.length, 0);
const investigationCount = clustersData.clusters.reduce((sum, cluster) => sum + investigationNotes(cluster).length, 0);
const clusterById = new Map(clustersData.clusters.map((cluster) => [cluster.id, cluster]));

function paper(slug: string) {
  const found = papersBySlug.get(slug);
  if (!found) throw new Error(`Missing paper for slug ${slug}`);
  return found;
}

function paperLine(item: PaperSummary) {
  return [item.year, item.venue].filter(Boolean).join(' / ') || 'Year or venue not specified';
}

function libraryHref(query: ClusterQuery) {
  const params = new URLSearchParams();
  Object.entries(query).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const encoded = params.toString();
  return encoded ? `/library/?${encoded}` : '/library/';
}

function allClusterPapers(cluster: typeof clustersData.clusters[number]) {
  return [...new Set([...cluster.representative_papers, ...cluster.supporting_papers])].map(paper);
}

function relatedClusters(cluster: typeof clustersData.clusters[number]) {
  return cluster.related_cluster_ids
    .map((id) => clusterById.get(id))
    .filter((item): item is typeof clustersData.clusters[number] => Boolean(item));
}

function investigationNotes(cluster: typeof clustersData.clusters[number]) {
  return ('working_group_investigations' in cluster ? cluster.working_group_investigations : []) ?? [];
}

function splitFlowStep(step: string) {
  const separator = step.indexOf(':');
  if (separator <= 0) return { label: '', text: step };
  return {
    label: step.slice(0, separator),
    text: step.slice(separator + 1).trim()
  };
}
---

<BaseLayout
  title={`CIM Library Clusters | ${profile.name}`}
  description="A cautious static cluster and working-group layer over the CIM compiler/IR paper corpus."
>
  <CimLibraryNav />
  <main class="wrap page-shell cluster-route">
    <header class="page-header">
      <p class="eyebrow eyebrow--dark">CIM compiler/IR corpus</p>
      <h1>Cluster and Working-Group Notes</h1>
      <p>{clustersData.scope_note}</p>
    </header>

    <section class="cluster-overview" aria-label="Cluster layer overview">
      <article class="landing-panel cluster-method">
        <p class="eyebrow eyebrow--dark">Analysis method</p>
        <h2>Metadata suggests candidates; paper content has to carry the claim</h2>
        <p>The cluster layer lives at <code>{clustersData.route}</code> and is sourced from <code>src/data/clusters.json</code>. It starts from the paper database, but a cluster should read as research synthesis: what object becomes first-class, how it is transformed or handed off, which notes/papers/artifacts support the claim, and where the boundary remains uncertain.</p>
        <div class="method-prose">
          {clustersData.methodology.map((item) => <p>{item}</p>)}
        </div>
      </article>
      <aside class="stat-board stat-board--landing">
        <div>
          <strong>{clustersData.clusters.length}</strong>
          <span>cluster hypotheses</span>
        </div>
        <div>
          <strong>{uniqueClusterPapers.size}</strong>
          <span>linked papers</span>
        </div>
        <div>
          <strong>{workingGroupCount}</strong>
          <span>coarse group notes</span>
        </div>
        <div>
          <strong>{investigationCount}</strong>
          <span>investigation notes</span>
        </div>
        <div>
          <strong>0</strong>
          <span>scores added</span>
        </div>
      </aside>
    </section>

    <section class="landing-panel cluster-focus-map" aria-label="Cluster focus map">
      <div class="section-title">
        <h2>Cluster Focus Map</h2>
        <span class="subtle">Start here: each row names the binding object before evidence detail.</span>
      </div>
      <div class="cluster-focus-list">
        {clustersData.clusters.map((cluster) => (
          <article>
            <div>
              <p class="eyebrow eyebrow--dark">{cluster.status}</p>
              <h3><a href={`#${cluster.id}`}>{cluster.short_label}</a></h3>
              <p>{cluster.binding_theme}</p>
            </div>
            <div class="cluster-focus-meta" aria-label={`Summary counts for ${cluster.short_label}`}>
              <span>{cluster.representative_papers.length} representative</span>
              <span>{cluster.supporting_papers.length} supporting</span>
              <span>{cluster.working_groups.length} group notes</span>
            </div>
            <a class="cluster-slice-link" href={libraryHref(cluster.atlas_query)}>Atlas slice</a>
          </article>
        ))}
      </div>
    </section>

    <section class="cluster-list" aria-label="CIM Library clusters">
      {clustersData.clusters.map((cluster) => {
        const papers = allClusterPapers(cluster);
        return (
          <article class="cluster-panel" id={cluster.id}>
            <div class="cluster-panel__header">
              <div>
                <p class="eyebrow eyebrow--dark">{cluster.status}</p>
                <h2>{cluster.label}</h2>
                <p>{cluster.summary}</p>
              </div>
            </div>

            <div class="cluster-detail-grid">
              <section class="cluster-detail-block cluster-focus-block">
                <h3>Binding theme</h3>
                <p>{cluster.binding_theme}</p>
              </section>
              <section class="cluster-detail-block">
                <h3>Uncertainty</h3>
                <p>{cluster.uncertainty}</p>
              </section>
            </div>

            <section class="cluster-flow" aria-label={`Object flow for ${cluster.label}`}>
              <h3>Object flow</h3>
              <ol>
                {cluster.object_flow.map((step) => {
                  const flowStep = splitFlowStep(step);
                  return (
                    <li>
                      {flowStep.label ? <b>{flowStep.label}</b> : null}
                      <span>{flowStep.text}</span>
                    </li>
                  );
                })}
              </ol>
            </section>

            <div class="cluster-cloud-grid">
              <section>
                <h3>Shared first-class objects</h3>
                <div class="cloud-nodes">
                  {cluster.shared_first_class_objects.map((item) => <span class="cloud-node object">{item}</span>)}
                </div>
              </section>
              <section>
                <h3>Shared rewrite objects</h3>
                <div class="cloud-nodes">
                  {cluster.shared_rewrite_objects.map((item) => <span class="cloud-node rewrite">{item}</span>)}
                </div>
              </section>
            </div>

            {relatedClusters(cluster).length ? (
              <section class="cluster-related" aria-label={`Related clusters for ${cluster.label}`}>
                <h3>Related cluster notes</h3>
                <div class="chip-row">
                  {relatedClusters(cluster).map((related) => <a class="chip" href={`#${related.id}`}>{related.short_label}</a>)}
                </div>
              </section>
            ) : null}

            <div class="cluster-lower-grid">
              <section class="cluster-paper-section">
                <div class="section-title">
                  <h3>Representative and supporting papers</h3>
                </div>
                <div class="cluster-paper-list">
                  {papers.map((item) => (
                    <article class={cluster.representative_papers.includes(item.slug) ? 'is-representative' : undefined}>
                      <div>
                        <p>{paperLine(item)}</p>
                        <h4><a href={item.route}>{item.title}</a></h4>
                      </div>
                      <span>{cluster.representative_papers.includes(item.slug) ? 'Representative' : 'Supporting'}</span>
                    </article>
                  ))}
                </div>
              </section>

              <section class="cluster-detail-stack" aria-label={`Evidence details for ${cluster.label}`}>
                <details open>
                  <summary>Evidence in current corpus</summary>
                  <ul class="plain-list">
                    {cluster.evidence.map((item) => <li>{item}</li>)}
                  </ul>
                </details>

                <details>
                  <summary>Coarse working-group notes</summary>
                  <div class="working-group-stack">
                    {cluster.working_groups.map((group) => (
                      <article>
                        <h4>{group.label}</h4>
                        <p><b>{group.relationship}</b></p>
                        <p>{group.evidence}</p>
                        <p class="subtle">{group.uncertainty}</p>
                        <div class="chip-row">
                          {group.representative_papers.map((slug) => <a class="chip" href={paper(slug).route}>{paper(slug).title}</a>)}
                        </div>
                      </article>
                    ))}
                  </div>
                </details>

                {investigationNotes(cluster).length ? (
                  <details>
                    <summary>Working-group investigation notes</summary>
                    <div class="investigation-stack">
                      {investigationNotes(cluster).map((note) => (
                        <article>
                          <div class="investigation-head">
                            <h4>{note.label}</h4>
                            <span>{note.status}</span>
                          </div>
                          <dl class="investigation-list">
                            <div>
                              <dt>Scope</dt>
                              <dd>{note.scope}</dd>
                            </div>
                            <div>
                              <dt>Why coherent</dt>
                              <dd>{note.why_coherent}</dd>
                            </div>
                            <div>
                              <dt>Boundary</dt>
                              <dd>{note.boundary}</dd>
                            </div>
                          </dl>
                          <div class="investigation-columns">
                            <section>
                              <h5>Continuity evidence</h5>
                              <ul class="plain-list">
                                {note.continuity_evidence.map((item) => <li>{item}</li>)}
                              </ul>
                            </section>
                            <section>
                              <h5>Next checks</h5>
                              <ul class="plain-list">
                                {note.next_checks.map((item) => <li>{item}</li>)}
                              </ul>
                            </section>
                          </div>
                          <div class="chip-row investigation-sources">
                            {note.source_links.map((source) => <a class="chip" href={source.url}>{source.label}</a>)}
                          </div>
                        </article>
                      ))}
                    </div>
                  </details>
                ) : null}
              </section>
            </div>
          </article>
        );
      })}
    </section>
  </main>
</BaseLayout>
