---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CimLibraryNav from '../../../components/CimLibraryNav.astro';
import ContentTag from '../../../components/ContentTag.astro';
import projects from '../../../data/project-registry.json';
import profile from '../../../data/profile.json';
import { sitePath } from '../../../lib/sitePath';
import cimManifest from '../../../../public/cim-library.manifest.json';

const project = projects.find((entry) => entry.id === 'cim-library');
if (!project) throw new Error('Missing cim-library project registry entry');

const topTechnologies = cimManifest.stats.top_technologies.slice(0, 6);
const topWorkloads = cimManifest.stats.top_workloads.slice(0, 6);
const clusterStats = cimManifest.cluster_layer?.stats;
const publicViews = cimManifest.views;
const routes = cimManifest.routes;
const methodologyRoute = routes.methodology ?? '/projects/cim-library/methodology/';
const repoUrl = project.repo;
const paperListRoute = routes.paper_list_markdown ?? '/cim-library-paper-list.md';
---

<BaseLayout
  title={`${project.title} | ${profile.name}`}
  description={project.summary}
>
  <CimLibraryNav />
  <ContentTag />
  <main class="wrap page-shell project-landing">
    <header class="page-header project-hero">
      <p class="eyebrow eyebrow--dark">{project.kind} / {project.status}</p>
      <h1>{project.title}</h1>
      <p>This library is a static, personal research atlas grown from paper investigation for my ongoing CIM IR work. It is meant to make a corpus easier to inspect, not to certify coverage, correctness, or importance.</p>
    </header>

    <section class="landing-grid landing-grid--intro" aria-label="CIM Library introduction">
      <article class="landing-panel landing-panel--wide">
        <p class="eyebrow eyebrow--dark">Reading frame</p>
        <h2>A subjective map of first-class CIM compiler objects</h2>
        <p class="overview-lede">The taxonomy asks what a stack makes explicit: what it names, types, rewrites, verifies, serializes, and hands to a backend. A paper may describe a macro generator, simulator, mapper, runtime, or ISA; the atlas records the representation boundary that seems most visible from the checked paper and artifact evidence.</p>
        <dl class="principle-list">
          <div>
            <dt>Personal best effort</dt>
            <dd>Coverage and note depth reflect my own investigation needs, source access, and time. Missing papers and uneven detail are expected.</dd>
          </div>
          <div>
            <dt>Descriptive, not authoritative</dt>
            <dd>The taxonomy is a subjective scope, and the content of any included paper note should be treated as a reading aid to verify, not as ground truth.</dd>
          </div>
          <div>
            <dt>Static and inspectable</dt>
            <dd>Paper metadata and notes live in Markdown; generated summaries come from a static manifest rather than a database or backend service.</dd>
          </div>
        </dl>
      </article>
      <aside class="stat-board stat-board--landing">
        <div>
          <strong>{cimManifest.stats.paper_count}</strong>
          <span>papers</span>
        </div>
        <div>
          <strong>{clusterStats?.cluster_count ?? 0}</strong>
          <span>clusters</span>
        </div>
        <div>
          <strong>{clusterStats?.linked_paper_count ?? 0}</strong>
          <span>cluster-linked papers</span>
        </div>
        <div>
          <strong>{cimManifest.stats.year_min}-{cimManifest.stats.year_max}</strong>
          <span>year range</span>
        </div>
      </aside>
    </section>

    <section class="landing-panel use-panel" aria-label="How to use this library">
      <div class="section-title">
        <div>
          <p class="eyebrow eyebrow--dark">How to use</p>
          <h2>Several recommended ways to read or reuse the library</h2>
        </div>
        <span class="subtle">Best used as a seed, not a citation substitute</span>
      </div>
      <ol class="use-list">
        <li>
          <span>Read and explore for fun.</span>
          <a class="inline-link" href={sitePath(routes.atlas)}>Open the atlas</a>
        </li>
        <li>
          <span>Export the paper list as a seed for your own investigation.</span>
          <a class="inline-link" href={sitePath(paperListRoute)}>Download paper list</a>
        </li>
        <li>
          <span>Export selected paper notes from <code>src/content/papers</code> as complementary material, then check the papers and artifacts yourself.</span>
          <a class="inline-link" href={sitePath(routes.paper_index)}>Open notes export</a>
        </li>
        <li>
          <span>Reference the methodology behind this taxonomy and corpus.</span>
          <a class="inline-link" href={sitePath(methodologyRoute)}>Open methodology</a>
        </li>
        <li>
          <span>Star the repository if this static homepage-library is useful to you.</span>
          <a class="inline-link" href={repoUrl}>Open GitHub</a>
        </li>
      </ol>
      <div class="library-contact-note">
        <p>For errors or new papers that should be covered, please email <a href={`mailto:${profile.email}`}>{profile.email}</a>. I deliberately do not maintain an active issue or pull-request queue for this library; the methodology page explains the reason.</p>
        <blockquote>
          <p>"The owl of Minerva spreads its wings only with the falling of the dusk."</p>
          <cite>G. W. F. Hegel, commonly translated from the preface to <em>Elements of the Philosophy of Right</em></cite>
        </blockquote>
      </div>
    </section>

    <section class="landing-panel project-surface-panel" aria-label="Public CIM Library surfaces">
      <div class="section-title">
        <div>
          <p class="eyebrow eyebrow--dark">Public surfaces</p>
          <h2>Static ways into the same corpus</h2>
        </div>
        <span class="subtle">Generated from the project manifest</span>
      </div>
      <div class="surface-list">
        {publicViews.map((view) => (
          <article>
            <h3>{view.label}</h3>
            <p>{view.description}</p>
            <code>{view.route}</code>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-grid" aria-label="Corpus shape">
      <article class="landing-panel">
        <p class="eyebrow eyebrow--dark">Corpus shape</p>
        <h2>Technology terms show where the papers spend their evidence</h2>
        <p class="facet-essay">The technology vocabulary is metadata, not the atlas axis. It helps expose whether a note is grounded in SRAM-CIM, RRAM/analog arrays, DRAM-PIM, UPMEM, or broader PIM compiler and runtime work.</p>
        <ul class="rank-list">
          {topTechnologies.map((item) => <li><span>{item.label}</span><b>{item.count}</b></li>)}
        </ul>
      </article>
      <article class="landing-panel">
        <p class="eyebrow eyebrow--dark">Workloads</p>
        <h2>Workload terms keep comparisons grounded</h2>
        <p class="facet-essay">Workload tags are kept separate from the taxonomy so an accelerator family, compiler layer, or runtime idea can be compared without mistaking benchmark coverage for representation quality.</p>
        <ul class="rank-list">
          {topWorkloads.map((item) => <li><span>{item.label}</span><b>{item.count}</b></li>)}
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>
