---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';
---

<BaseLayout
  title={`About | ${profile.name}`}
  description={`${profile.name} is a Ph.D. student at ${profile.institution} focused on Compute-in-Memory architecture, memristor devices, and research tooling.`}
>
  <main class="wrap page-shell">
    <header class="page-header about-header">
      <p class="eyebrow eyebrow--dark">About</p>
      <h1>{profile.name}</h1>
      <p class="native-name">{profile.native_name}</p>
      <p>{profile.profile_summary}</p>
      <div class="profile-contact">
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        <span>{profile.location}</span>
        <span>{profile.institution}</span>
      </div>
    </header>

    <section class="about-grid" aria-label="Profile details">
      <article class="profile-panel about-panel">
        <p class="eyebrow eyebrow--dark">Research Focus</p>
        <h2>Current work</h2>
        <ul class="focus-list focus-list--single">
          {profile.research_focus.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <aside class="profile-panel about-panel">
        <p class="eyebrow eyebrow--dark">Education</p>
        <h2>Training</h2>
        <dl class="compact-facts">
          {profile.education.map((item) => (
            <div>
              <dt>{item.period}</dt>
              <dd>{item.degree}<span>{item.school} / {item.location}</span></dd>
            </div>
          ))}
        </dl>
      </aside>
    </section>

    <section class="home-section" aria-labelledby="about-publications">
      <div class="section-title">
        <div>
          <p class="eyebrow eyebrow--dark">Selected Publications</p>
          <h2 id="about-publications">Research record</h2>
        </div>
      </div>
      <div class="publication-list publication-list--about">
        {profile.publications.map((publication) => (
          <article>
            <h3>{publication.title}</h3>
            <p>{publication.venue} / {publication.year}{publication.role ? ` / ${publication.role}` : ''}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
