---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import profile from '../data/profile.json';
import projects from '../data/project-registry.json';
import cimManifest from '../../public/cim-library.manifest.json';

const featuredProjects = projects.filter((project) => project.featured);
---

<BaseLayout
  title={`${profile.name} | Research and Projects`}
  description={`${profile.name} is a Ph.D. student at ${profile.institution} working on Compute-in-Memory architecture, memristor devices, and research tooling.`}
>
  <main class="site-home">
    <header class="wrap page-header home-intro">
      <p class="eyebrow eyebrow--dark">{profile.current_role}</p>
      <h1>{profile.name}</h1>
      <p class="home-hero__native">{profile.native_name}</p>
      <p>{profile.profile_summary}</p>
    </header>

    <nav class="wrap dag-index" aria-labelledby="site-index">
      <h2 id="site-index">Index</h2>
      <ol>
        <li>
          <a href="/about/">Profile</a>
          <span>research focus, education, publications, contact</span>
        </li>
        <li>
          <a href="/projects/">Projects</a>
          <span>static research systems and development tools</span>
        </li>
        <li>
          <a href="/projects/cim-library/">CIM Library project</a>
          <span>why the paper atlas exists and how it is maintained</span>
        </li>
        <li>
          <a href="/library/">CIM atlas</a>
          <span>{cimManifest.stats.paper_count} papers classified across Axis A/B/C/D</span>
        </li>
        <li>
          <a href="/papers/cimflow/">Representative paper notes</a>
          <span>individual Markdown corpus notes under stable slugs</span>
        </li>
      </ol>
    </nav>

    <section class="wrap home-grid" aria-label="Research map">
      <div class="profile-panel">
        <p class="eyebrow eyebrow--dark">Research Map</p>
        <h2>Computing systems from devices to compiler abstractions</h2>
        <ul class="thread-list">
          <li>
            <span>Device behavior</span>
            <a href="/about/">memristor and 2D-material computing</a>
          </li>
          <li>
            <span>Architecture</span>
            <a href="/projects/cim-library/">Compute-in-Memory stacks</a>
          </li>
          <li>
            <span>Compiler objects</span>
            <a href="/library/?layout=cd">first-class objects and rewrites</a>
          </li>
          <li>
            <span>Corpus tooling</span>
            <a href="/projects/">static atlases and registries</a>
          </li>
        </ul>
      </div>

      <aside class="profile-panel profile-panel--compact">
        <p class="eyebrow eyebrow--dark">Current Base</p>
        <h2>{profile.institution}</h2>
        <p>{profile.location}</p>
        <div class="mini-index">
          <a href="/about/">About</a>
          <a href={`mailto:${profile.email}`}>Email</a>
        </div>
      </aside>
    </section>

    <section class="wrap home-section" aria-labelledby="featured-projects">
      <div class="section-title">
        <h2 id="featured-projects">Featured project</h2>
        <a class="inline-link" href="/projects/">All projects</a>
      </div>
      <div class="project-grid">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="wrap home-section atlas-summary" aria-labelledby="atlas-summary-heading">
      <div>
        <p class="eyebrow eyebrow--dark">CIM Library Snapshot</p>
        <h2 id="atlas-summary-heading">{cimManifest.stats.paper_count} papers across {cimManifest.stats.year_min}-{cimManifest.stats.year_max}</h2>
        <p>The atlas organizes Compute-in-Memory compiler and IR work by stack role, middle-layer representation, first-class objects, and rewrite objects. Start from the <a href="/projects/cim-library/">project page</a>, open the <a href="/library/">full atlas</a>, or go directly to the <a href="/library/?layout=cd">Axis C/D view</a>.</p>
      </div>
      <div class="stat-board" aria-label="CIM Library statistics">
        <div>
          <strong>{Object.keys(cimManifest.stats.axis_A_counts).length}</strong>
          <span>Axis A roles</span>
        </div>
        <div>
          <strong>{Object.keys(cimManifest.stats.axis_B_counts).length}</strong>
          <span>Axis B styles</span>
        </div>
        <div>
          <strong>{Object.keys(cimManifest.stats.axis_C_object_vocab_counts).length}</strong>
          <span>Object families</span>
        </div>
        <div>
          <strong>{Object.keys(cimManifest.stats.axis_D_rewrite_type_counts).length}</strong>
          <span>Rewrite families</span>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
