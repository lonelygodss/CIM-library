---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Paper Library">
  <header class="hero wrap">
    <div class="hero-card">
      <div class="eyebrow"><span class="dot"></span> Static corpus draft</div>
      <h1>CIM Compiler/IR Paper Library</h1>
      <p>Browse the taxonomy atlas or open individual paper notes generated from Markdown content.</p>
    </div>
  </header>
  <main class="wrap">
    <section class="panel pad">
      <h2>Start here</h2>
      <p><a class="badge" href="/library/">Open the library atlas</a></p>
    </section>
  </main>
</BaseLayout>
