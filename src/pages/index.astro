---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile.json';

function publicationMeta(publication: {
  venue: string;
  year: number;
  details?: string;
  pages?: string;
  role?: string;
}) {
  return [
    publication.venue,
    publication.year,
    publication.details,
    publication.pages ? `pp. ${publication.pages}` : null,
    publication.role
  ].filter(Boolean).join(' / ');
}

function publicationAuthors(publication: { authors?: string[] }) {
  return publication.authors?.length ? publication.authors.join(', ') : '';
}
---

<BaseLayout
  title={`${profile.name} | Research`}
  description={`${profile.name} is a Ph.D. student at ${profile.institution} working on Compute-in-Memory architecture, memristor devices, and research tooling.`}
>
  <main class="site-home">
    <header class="wrap page-header home-intro">
      <p class="eyebrow eyebrow--dark">{profile.current_role}</p>
      <h1>{profile.name}</h1>
      <p class="native-name">{profile.native_name}</p>
      <p>{profile.profile_summary}</p>
      <div class="profile-contact">
        <a href={`mailto:${profile.email}`}>{profile.email}</a>
        <span>{profile.location}</span>
        <span>{profile.institution}</span>
      </div>
    </header>

    <section class="wrap about-grid" aria-label="Profile details">
      <article class="profile-panel about-panel">
        <p class="eyebrow eyebrow--dark">Research Focus</p>
        <h2>Current work</h2>
        <ul class="focus-list focus-list--single">
          {profile.research_focus.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <aside class="profile-panel about-panel">
        <p class="eyebrow eyebrow--dark">Education</p>
        <h2>Training</h2>
        <dl class="compact-facts">
          {profile.education.map((item) => (
            <div>
              <dt>{item.period}</dt>
              <dd>{item.degree}<span>{item.school} / {item.location}</span></dd>
            </div>
          ))}
        </dl>
      </aside>
    </section>

    <section class="wrap home-section" aria-labelledby="home-projects">
      <div class="section-title">
        <div>
          <p class="eyebrow eyebrow--dark">Projects</p>
          <h2 id="home-projects">Research projects live on the project index</h2>
        </div>
        <a class="inline-link" href="/projects/">Open projects</a>
      </div>
    </section>

    <section class="wrap home-section" aria-labelledby="home-publications">
      <div class="section-title">
        <div>
          <p class="eyebrow eyebrow--dark">Selected Publications</p>
          <h2 id="home-publications">Research record</h2>
        </div>
      </div>
      <div class="publication-list publication-list--about">
        {profile.publications.map((publication) => (
          <article>
            <h3>
              {publication.url ? (
                <a href={publication.url}>{publication.title}</a>
              ) : (
                publication.title
              )}
            </h3>
            {publicationAuthors(publication) && <p class="publication-authors">{publicationAuthors(publication)}</p>}
            <p>{publicationMeta(publication)}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
