---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import taxonomy from '../../data/taxonomy.json';
import { normalizePaperAxes } from '../../lib/axisNormalization';

export async function getStaticPaths() {
  const papers = await getCollection('papers');
  return papers.map((paper) => ({
    params: { slug: paper.data.slug },
    props: { paper }
  }));
}

const { paper } = Astro.props;
const { Content, headings } = await render(paper);
const data = paper.data;

const axisAEntries = [data.axis_A.primary, ...(data.axis_A.secondary ?? [])].map((code) => ({
  code,
  label: taxonomy.families[code]?.name ?? code,
  short: taxonomy.families[code]?.short ?? code
}));
const axisBEntries = data.axis_B.map((code) => ({
  code,
  label: taxonomy.middles[code]?.name ?? code,
  short: taxonomy.middles[code]?.short ?? code,
  desc: taxonomy.middles[code]?.desc ?? ''
}));
const sourceLabels: Record<string, string> = {
  paper: 'Paper',
  artifact: 'Artifact',
  docs: 'Docs',
  code: 'Code'
};
const sourceDescriptions: Record<string, string> = {
  paper: 'Primary publication or paper PDF',
  artifact: 'Project, release, dataset, or artifact landing page',
  docs: 'Official usage or architecture documentation',
  code: 'Source repository'
};
const sourceHost = (url: string) => {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
};
const linkEntries = Object.entries(data.links ?? {}).flatMap(([kind, url]) => {
  if (!url) return [];
  return [{
    kind,
    label: sourceLabels[kind] ?? kind,
    description: sourceDescriptions[kind] ?? 'Recorded source link',
    url,
    host: sourceHost(url)
  }];
});
if (data.artifact?.url && !linkEntries.some((entry) => entry.url === data.artifact.url)) {
  linkEntries.push({
    kind: 'artifact',
    label: sourceLabels.artifact,
    description: sourceDescriptions.artifact,
    url: data.artifact.url,
    host: sourceHost(data.artifact.url)
  });
}
const normalizedAxes = normalizePaperAxes(data, taxonomy);
const atlasFacetHref = (params: Record<string, string>) => {
  const search = new URLSearchParams({ paper: data.slug, ...params });
  return `/?${search.toString()}#atlas-section`;
};
const noteOutline = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
type NoteHeading = typeof noteOutline[number];
type NoteSection = NoteHeading & { children: NoteHeading[] };
const noteSections: NoteSection[] = [];
for (const heading of noteOutline) {
  if (heading.depth === 2 || noteSections.length === 0) {
    noteSections.push({ ...heading, children: [] });
  } else {
    noteSections[noteSections.length - 1].children.push(heading);
  }
}
const paperMeta = [data.year, data.venue, data.authors_or_group].filter(Boolean).join(' · ');
const emptyLabel = 'Unknown / not specified';
const artifactChecked = data.artifact.last_checked ?? emptyLabel;
const artifactUrlRecorded = Boolean(data.artifact?.url || data.links?.artifact);
const provenanceSummary = [
  { label: 'Paper source', value: data.links?.paper ? 'Recorded' : emptyLabel },
  { label: 'Artifact link', value: artifactUrlRecorded ? 'Recorded' : emptyLabel },
  { label: 'Artifact status', value: data.artifact.status },
  { label: 'Last checked', value: artifactChecked }
];
---
<BaseLayout title={`${data.title} — Paper Library`} description={data.summary}>
  <header class="paper-hero wrap">
    <div class="paper-hero-inner">
      <div class="eyebrow"><span class="dot"></span> Corpus note</div>
      <h1>{data.title}</h1>
      {paperMeta && <p class="paper-meta-line">{paperMeta}</p>}
      <p class="paper-hero-summary">{data.summary}</p>
      <div class="paper-hero-actions">
        <a class="chip dark" href="/" data-atlas-back>Back to atlas</a>
        {linkEntries.map((entry) => <a class="chip dark" href={entry.url}>{entry.label}</a>)}
      </div>
    </div>
  </header>
  <main class="wrap paper-detail">
    <section class="provenance-strip" aria-label="Source provenance summary">
      {provenanceSummary.map((item) => (
        <div class="provenance-item">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </section>
    <section class="detail-overview" aria-label="Paper metadata overview">
      <div class="detail-panel">
        <h2>Taxonomy placement</h2>
        <div class="axis-stack">
          <div>
            <h3>Axis A: stack role</h3>
            <div class="axis-list compact">
              {axisAEntries.map((item, index) => (
                <div class="axis-row">
                  <code>{item.code}</code>
                  <span><b>{index === 0 ? 'Primary' : 'Secondary'}: {item.short}</b>{item.label}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h3>Axis B: middle layer</h3>
            <div class="axis-list compact">
              {axisBEntries.map((item) => (
                <div class="axis-row">
                  <code>{item.code}</code>
                  <span><b>{item.short}</b>{item.desc}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div class="detail-panel">
        <h2>Compiler-facing objects</h2>
        <div class="object-rewrite-grid">
          <section>
            <h3>Axis C: first-class objects</h3>
            <div class="cloud-nodes detail-cloud">
              {data.axis_C_first_class_objects.length
                ? data.axis_C_first_class_objects.map((item) => <span class="cloud-node object">{item}</span>)
                : <span class="cloud-node more">{emptyLabel}</span>}
            </div>
          </section>
          <section>
            <h3>Normalized Axis C categories</h3>
            <div class="cloud-nodes detail-cloud">
              {normalizedAxes.axis_C_object_vocab.length
                ? normalizedAxes.axis_C_object_vocab.map((item) => <a class="cloud-node object facet-link" href={atlasFacetHref({ layout: 'cd', c: item })}>{item}</a>)
                : <span class="cloud-node more">{emptyLabel}</span>}
            </div>
          </section>
          <section>
            <h3>Axis D: rewrite objects</h3>
            <div class="cloud-nodes detail-cloud">
              {data.axis_D_rewrite_objects.length
                ? data.axis_D_rewrite_objects.map((item) => <span class="cloud-node rewrite">{item}</span>)
                : <span class="cloud-node more">{emptyLabel}</span>}
            </div>
          </section>
          <section>
            <h3>Normalized Axis D types</h3>
            <div class="cloud-nodes detail-cloud">
              {normalizedAxes.axis_D_rewrite_types.length
                ? normalizedAxes.axis_D_rewrite_types.map((item) => <a class="cloud-node rewrite facet-link" href={atlasFacetHref({ layout: 'cd', d: item })}>{item}</a>)
                : <span class="cloud-node more">{emptyLabel}</span>}
            </div>
          </section>
        </div>
      </div>
    </section>

    <div class:list={['paper-layout', { 'without-outline': noteSections.length === 0 }]}>
      {noteSections.length > 0 && (
        <nav class="note-outline section-nav" aria-label="Corpus note outline">
          <div class="section-nav-title">Note outline</div>
          <div class="outline-stack">
            {noteSections.map((section) => (
              section.children.length > 0 ? (
                <details class="outline-section">
                  <summary>
                    <a class="outline-summary-link" href={`#${section.slug}`}>{section.text}</a>
                  </summary>
                  <ol>
                    {section.children.map((heading) => (
                      <li>
                        <a href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ol>
                </details>
              ) : (
                <div class="outline-section outline-leaf">
                  <a href={`#${section.slug}`}>{section.text}</a>
                </div>
              )
            ))}
          </div>
        </nav>
      )}
      <article class="prose paper-prose">
        <Content />
      </article>
      <aside class="sidebar paper-sidebar">
        <div class="panel pad metadata-panel">
          <h2>Scan metadata</h2>
          <dl class="metadata-list">
            <div><dt>Year</dt><dd>{data.year ?? emptyLabel}</dd></div>
            <div><dt>Venue</dt><dd>{data.venue ?? emptyLabel}</dd></div>
            <div><dt>Reproducibility</dt><dd>{data.reproducibility_level}</dd></div>
            <div><dt>Artifact status</dt><dd>{data.artifact.status}</dd></div>
            <div><dt>Last checked</dt><dd>{data.artifact.last_checked ?? emptyLabel}</dd></div>
            <div><dt>License</dt><dd>{data.artifact.license || emptyLabel}</dd></div>
          </dl>
        </div>
        <div class="panel pad">
          <h2>Sources</h2>
          <div class="source-list">
            {linkEntries.length
              ? linkEntries.map((entry) => (
                <a class="source-link" href={entry.url}>
                  <span>
                    <b>{entry.label}</b>
                    <small>{entry.description}</small>
                  </span>
                  <em>{entry.host}</em>
                </a>
              ))
              : <span class="subtle">No external links recorded in frontmatter.</span>}
          </div>
          <p class="source-note">
            Source links are descriptive frontmatter metadata. Artifact status and last-checked date reflect the latest recorded corpus pass, not a live availability monitor.
          </p>
        </div>
        <div class="panel pad">
          <h2>Context</h2>
          <div class="cloud-nodes detail-cloud">
            {data.technology.length || data.workloads.length
              ? (
                <>
                  {data.technology.map((item) => <a class="cloud-node context facet-link" href={atlasFacetHref({ tech: item })}>{item}</a>)}
                  {data.workloads.map((item) => <a class="cloud-node context facet-link" href={atlasFacetHref({ workload: item })}>{item}</a>)}
                </>
              )
              : <span class="cloud-node more">{emptyLabel}</span>}
          </div>
        </div>
        {data.integration_roles.length > 0 && (
          <div class="panel pad">
            <h2>Integration roles</h2>
            <ul class="plain-list">
              {data.integration_roles.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </main>
  <footer class="wrap footer">Static corpus note. Frontmatter is the source for atlas metadata; the note body preserves the public long-form reading.</footer>
  <script is:inline>
    (() => {
      const from = new URLSearchParams(window.location.search).get('from');
      if (!from || !from.startsWith('/') || from.startsWith('//')) return;
      document.querySelectorAll('[data-atlas-back]').forEach((link) => {
        link.setAttribute('href', from);
      });
    })();
  </script>
  <script is:inline>
    (() => {
      document.querySelectorAll('.outline-summary-link').forEach((link) => {
        link.addEventListener('click', (event) => event.stopPropagation());
      });
    })();
  </script>
</BaseLayout>
