---
import '../styles/global.css';
import cimManifest from '../../public/cim-library.manifest.json';
import { routePath, sitePath } from '../lib/sitePath';

const {
  title = 'Zijian Xiong',
  description = 'Research projects and Compute-in-Memory compiler/IR paper atlas.'
} = Astro.props;

const currentPath = routePath(Astro.url.pathname);
const cimRoutes = cimManifest.routes;
const cimLibraryPrefixes = [cimRoutes.project, cimRoutes.atlas, cimRoutes.clusters, '/papers/'];
const navLinks = [
  { href: '/', label: 'Home', section: 'home' },
  { href: '/projects/', label: 'Projects', section: 'projects' },
  { href: cimRoutes.project, label: 'CIM Library', section: 'cim-library' }
];

function inCimLibrary() {
  return cimLibraryPrefixes.some((prefix) => currentPath.startsWith(prefix));
}

function isCurrent(section: string) {
  if (section === 'home') return currentPath === '/';
  if (section === 'cim-library') return inCimLibrary();
  if (section === 'projects') return currentPath.startsWith('/projects/') && !inCimLibrary();
  return false;
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav" aria-label="Primary navigation">
      <div class="site-nav-inner wrap">
        <a class="site-brand" href={sitePath('/')}>Zijian Xiong</a>
        <div class="site-links">
          {navLinks.map((link) => (
            <a href={sitePath(link.href)} aria-current={isCurrent(link.section) ? 'page' : undefined}>{link.label}</a>
          ))}
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>
