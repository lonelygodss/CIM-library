---
import { axisCategorySets, normalizePaperAxes } from '../lib/axisNormalization';
import { basePath } from '../lib/sitePath';

type AxisA = 'A1' | 'A2' | 'A3' | 'A4' | 'A5' | 'A6';
type AxisB = 'B1' | 'B2' | 'B3' | 'B4' | 'B5' | 'B6' | 'B7';

type Family = {
  name: string;
  short: string;
  artifact: string;
  color: string;
};

type Middle = {
  name: string;
  short: string;
  desc: string;
};

type Paper = {
  slug: string;
  title: string;
  short_title: string;
  subtitle?: string | null;
  year?: number | null;
  publication?: {
    venue?: string | null;
    type?: string | null;
    doi?: string | null;
    url?: string | null;
  };
  summary: string;
  tags?: string[];
  technology?: string[];
  workloads?: string[];
  baselines?: string[];
  integration_roles?: string[];
  notes?: string[];
  takeaways?: string[];
  axis_A: {
    primary: AxisA;
    secondary?: AxisA[];
  };
  axis_B: AxisB[];
  axis_C_first_class_objects?: string[];
  axis_D_rewrite_objects?: string[];
  axis_C_object_vocab?: string[];
  axis_D_rewrite_types?: string[];
};

type Taxonomy = {
  families: Record<AxisA, Family>;
  middles: Record<AxisB, Middle>;
  objects_vocab?: string[];
  rewrite_types?: Record<string, string>;
};

interface Props {
  papers: Paper[];
  taxonomy: Taxonomy;
}

const { papers, taxonomy } = Astro.props;
const normalizedPapers = papers.map((paper) => ({
  ...paper,
  ...normalizePaperAxes(paper, taxonomy)
}));
const axisCategories = axisCategorySets(taxonomy);
---
<section id="atlas-section" class="panel pad">
  <div class="section-title">
    <div>
      <h2>Interactive paper atlas</h2>
      <div class="subtle">Each circle is a paper. Switch between the stack-role view and the normalized object/rewrite view; hover previews the paper footprint, while click pins the compact reading bridge.</div>
    </div>
    <div class="atlas-count" id="filteredStats" aria-live="polite"></div>
  </div>
  <div class="layout-toggle" role="group" aria-label="Atlas layout">
    <button id="layoutAB" type="button" data-layout="ab" aria-pressed="true">Axis A x B</button>
    <button id="layoutCD" type="button" data-layout="cd" aria-pressed="false">Axis C x D</button>
  </div>
  <div class="controls" aria-label="Taxonomy filters">
    <input id="search" type="search" placeholder="Search paper, abstraction, object, evidence..." aria-label="Search papers" />
    <select id="familyFilter" aria-label="Filter by stack role"></select>
    <select id="middleFilter" aria-label="Filter by middle-layer style"></select>
    <select id="objectFilter" aria-label="Filter by normalized first-class object"></select>
    <select id="rewriteFilter" aria-label="Filter by normalized rewrite object"></select>
    <select id="technologyFilter" aria-label="Filter by technology"></select>
    <select id="workloadFilter" aria-label="Filter by workload"></select>
  </div>
  <div class="paper-picker-row" aria-label="Paper selection">
    <label for="paperPicker">Selected paper</label>
    <select id="paperPicker" aria-label="Select paper from filtered results"></select>
    <button id="resetFilters" type="button" class="secondary">Reset filters</button>
  </div>
  <div class="viz-grid">
    <div class="panel viz-card atlas-box">
      <svg id="atlas" viewBox="0 0 1180 660" preserveAspectRatio="xMidYMid meet" role="img" aria-label="CIM taxonomy atlas"></svg>
      <div class="legend" id="familyLegend"></div>
    </div>
    <aside class="selected-panel" aria-live="polite">
      <div id="workDetails" class="empty">Select a paper.</div>
      <div id="workMore"></div>
    </aside>
  </div>
  <div id="clusterSummary" class="cluster-summary" aria-live="polite"></div>
  <div id="atlasTooltip" class="atlas-tooltip" role="status" aria-hidden="true"></div>
</section>

<section id="taxonomy" class="panel pad taxonomy-support">
  <div class="section-title">
    <div>
      <h2>Taxonomy axes</h2>
      <div class="subtle">Technology such as SRAM, RRAM, DRAM-PIM, CAM, or UPMEM is metadata; workloads are filtered separately. The atlas itself is organized by stack artifact and abstraction style.</div>
    </div>
  </div>
  <div class="axis-explainer">
    <div>
      <h3>Axis A — stack role</h3>
      <div class="axis-list">
        {Object.entries(taxonomy.families).map(([code, family]) => (
          <div class="axis-row">
            <code>{code}</code>
            <span><b>{family.name}</b>{family.artifact}</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h3>Axis B — middle-layer style</h3>
      <div class="axis-list">
        {Object.entries(taxonomy.middles).map(([code, middle]) => (
          <div class="axis-row">
            <code>{code}</code>
            <span><b>{middle.name}</b>{middle.desc}</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h3>Axis C — first-class object vocabulary</h3>
      <div class="axis-list">
        {(taxonomy.objects_vocab ?? []).map((term) => (
          <div class="axis-row">
            <code>C</code>
            <span><b>{term}</b>Controlled object category derived from paper frontmatter terms.</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h3>Axis D — rewrite vocabulary</h3>
      <div class="axis-list">
        {Object.entries(taxonomy.rewrite_types ?? {}).map(([code, label]) => (
          <div class="axis-row">
            <code>D</code>
            <span><b>{label}</b>{code} category derived from paper frontmatter terms.</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline type="application/json" id="paper-data" set:html={JSON.stringify(normalizedPapers)}></script>
<script is:inline type="application/json" id="taxonomy-data" set:html={JSON.stringify(taxonomy)}></script>
<script is:inline type="application/json" id="axis-category-data" set:html={JSON.stringify(axisCategories)}></script>
<script is:inline type="application/json" id="site-base-path" set:html={JSON.stringify(basePath)}></script>
<script is:inline>
(() => {
  const papers = JSON.parse(document.getElementById('paper-data').textContent);
  const taxonomy = JSON.parse(document.getElementById('taxonomy-data').textContent);
  const axisCategories = JSON.parse(document.getElementById('axis-category-data').textContent);
  const siteBasePath = JSON.parse(document.getElementById('site-base-path').textContent);
  const families = taxonomy.families;
  const middles = taxonomy.middles;
  const familyCodes = Object.keys(families);
  const middleCodes = Object.keys(middles);
  const objectCategories = axisCategories.objectCategories;
  const rewriteCategories = axisCategories.rewriteCategories;
  const svgNS = 'http://www.w3.org/2000/svg';
  const atlasProfiles = {
    ab: {
      width: 1320,
      height: 720,
      xLeft: 158,
      xRight: 1248,
      yTop: 126,
      yBottom: 648,
      xLabelY: 38,
      xSubLabelY: 63,
      yCodeX: 58,
      yLabelX: 58,
      gridTop: 86,
      gridBottom: 680,
      gridLeft: 120,
      gridRight: 1278,
      fontCode: 18,
      fontLabel: 13,
      nodeR: 10.5,
      hoverR: 17,
      nodeFont: 10.5,
      hoverFont: 13
    },
    cd: {
      width: 1380,
      height: 780,
      xLeft: 226,
      xRight: 1308,
      yTop: 148,
      yBottom: 704,
      xLabelY: 54,
      yLabelX: 24,
      gridTop: 124,
      gridBottom: 742,
      gridLeft: 190,
      gridRight: 1338,
      fontCode: 13,
      fontLabel: 13,
      nodeR: 10.5,
      hoverR: 17,
      nodeFont: 10.5,
      hoverFont: 13
    }
  };
  let selectedSlug = papers[0]?.slug ?? null;
  let hoveredSlug = null;
  let filtered = [...papers];
  let activeTooltipPaper = null;
  let currentNodeHits = [];
  let atlasLayout = 'ab';
  let scopedCell = null;

  const $ = (id) => document.getElementById(id);
  const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[m]));
  const inlineMarkdown = (value) => esc(value)
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*]+)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+)\)/g, '<a href="$2">$1</a>');
  const firstMiddle = (paper) => paper.axis_B?.[0] ?? 'B1';
  const roles = (paper) => [paper.axis_A.primary, ...(paper.axis_A.secondary ?? [])];
  const metadataLine = (paper) => [paper.year, paper.publication?.venue].filter(Boolean).join(' · ');
  const currentAtlasUrl = () => `${window.location.pathname}${window.location.search}`;
  const sitePath = (path) => `${siteBasePath}${path.startsWith('/') ? path : `/${path}`}` || '/';
  const detailHref = (paper) => `${sitePath(`/papers/${paper.slug}/`)}?from=${encodeURIComponent(currentAtlasUrl())}`;
  const paperLabel = (paper) => paper.title;
  const shortTitle = (paper) => paper.short_title || paper.title;
  const initials = (paper) => shortTitle(paper)
    .replace(/[^A-Za-z0-9+]+/g, ' ')
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 3)
    .map((x) => x[0])
    .join('')
    .toUpperCase();
  const textBlob = (paper) => [
    paper.title,
    paper.short_title,
    paper.subtitle,
    paper.summary,
    ...(paper.tags ?? []),
    ...(paper.technology ?? []),
    ...(paper.workloads ?? []),
    ...(paper.baselines ?? []),
    ...(paper.axis_C_first_class_objects ?? []),
    ...(paper.axis_D_rewrite_objects ?? []),
    ...(paper.axis_C_object_vocab ?? []),
    ...(paper.axis_D_rewrite_types ?? [])
  ].join(' ').toLowerCase();
  const uniqueTerms = (items) => [...new Set(items.flat().filter(Boolean))].sort((a, b) => a.localeCompare(b));
  const clear = (node) => { while (node.firstChild) node.removeChild(node.firstChild); };
  const node = (name, attrs = {}, text = '') => {
    const el = document.createElementNS(svgNS, name);
    Object.entries(attrs).forEach(([key, value]) => el.setAttribute(key, value));
    if (text) el.textContent = text;
    return el;
  };
  const atlasProfile = () => atlasProfiles[atlasLayout];
  const splitLabel = (label, limit = 13) => {
    const words = String(label ?? '').split(/\s+/).filter(Boolean);
    if (!words.length || label.length <= limit) return [label];
    const lines = [];
    let current = '';
    words.forEach((word) => {
      const next = current ? `${current} ${word}` : word;
      if (next.length <= limit || !current) current = next;
      else {
        lines.push(current);
        current = word;
      }
    });
    if (current) lines.push(current);
    return lines.slice(0, 2);
  };
  const appendText = (parent, attrs = {}, text = '', lines = null, lineDy = 15) => {
    const el = node('text', attrs);
    const textLines = lines ?? [text];
    textLines.forEach((line, index) => {
      const tspan = node('tspan', { x: attrs.x, dy: index === 0 ? 0 : lineDy }, line);
      el.append(tspan);
    });
    parent.append(el);
    return el;
  };
  const listText = (items, fallback = 'Not specified') => {
    const values = (items ?? []).filter(Boolean);
    return values.length ? values.join(', ') : fallback;
  };
  const clippedList = (items, limit = 3) => (items ?? []).filter(Boolean).slice(0, limit);
  const axisLabel = (paper) => {
    const family = families[paper.axis_A.primary];
    const middle = middles[firstMiddle(paper)];
    return `${paper.axis_A.primary} ${family?.short ?? ''} / ${firstMiddle(paper)} ${middle?.short ?? ''}`.trim();
  };
  const objectRewriteLabel = (paper) => {
    const objects = clippedList(paper.axis_C_object_vocab, 2);
    const rewrites = clippedList(paper.axis_D_rewrite_types, 2);
    return `${listText(objects)} / ${listText(rewrites)}`;
  };
  const bridgeBullets = (paper) => {
    const takeaways = clippedList(paper.takeaways, 3);
    if (takeaways.length) return takeaways;
    const roles = clippedList(paper.integration_roles, 3);
    if (roles.length) return roles.map((role) => `Useful as ${role.replace(/_/g, ' ')}`);
    return [paper.summary];
  };
  const chips = (items, cls, limit = 4) => {
    const values = clippedList(items, limit);
    return values.length
      ? values.map((item) => `<span class="cloud-node ${cls}">${esc(item)}</span>`).join('')
      : '<span class="cloud-node more">Not specified</span>';
  };

  function cellKey(paper) {
    return atlasLayout === 'cd'
      ? `${paper.axis_C_object_vocab?.[0]}:${paper.axis_D_rewrite_types?.[0]}`
      : `${paper.axis_A.primary}:${firstMiddle(paper)}`;
  }

  function groupedPositions(items) {
    const groups = new Map();
    items.forEach((paper) => {
      const key = cellKey(paper);
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key).push(paper);
    });
    const positions = new Map();
    groups.forEach((group) => {
      const sorted = [...group].sort((a, b) => a.title.localeCompare(b.title));
      const n = sorted.length;
      sorted.forEach((paper, index) => {
        const ring = Math.ceil(Math.sqrt(index + 1));
        const angle = (index * 2.399963229728653) % (Math.PI * 2);
        const scale = n > 14 ? 8.5 : n > 8 ? 10 : 11.5;
        positions.set(paper.slug, {
          dx: Math.cos(angle) * ring * scale,
          dy: Math.sin(angle) * ring * scale
        });
      });
    });
    return positions;
  }
  function setupFilters() {
    const familyFilter = $('familyFilter');
    const middleFilter = $('middleFilter');
    const objectFilter = $('objectFilter');
    const rewriteFilter = $('rewriteFilter');
    const technologyFilter = $('technologyFilter');
    const workloadFilter = $('workloadFilter');
    familyFilter.innerHTML = `<option value="">All Axis A roles</option>` + familyCodes.map((code) => `<option value="${code}">${code} — ${esc(families[code].short)}</option>`).join('');
    middleFilter.innerHTML = `<option value="">All Axis B styles</option>` + middleCodes.map((code) => `<option value="${code}">${code} — ${esc(middles[code].short)}</option>`).join('');
    objectFilter.innerHTML = `<option value="">All Axis C objects</option>` + objectCategories.map((tag) => `<option value="${esc(tag)}">${esc(tag)}</option>`).join('');
    rewriteFilter.innerHTML = `<option value="">All Axis D rewrites</option>` + rewriteCategories.map((tag) => `<option value="${esc(tag)}">${esc(tag)}</option>`).join('');
    const technologies = uniqueTerms(papers.map((p) => p.technology ?? []));
    const workloads = uniqueTerms(papers.map((p) => p.workloads ?? []));
    technologyFilter.innerHTML = `<option value="">All technologies</option>` + technologies.map((tag) => `<option value="${esc(tag)}">${esc(tag)}</option>`).join('');
    workloadFilter.innerHTML = `<option value="">All workloads</option>` + workloads.map((tag) => `<option value="${esc(tag)}">${esc(tag)}</option>`).join('');
    ['search', 'familyFilter', 'middleFilter', 'objectFilter', 'rewriteFilter', 'technologyFilter', 'workloadFilter'].forEach((id) => $(id).addEventListener('input', () => {
      scopedCell = null;
      applyFilters();
    }));
    document.querySelectorAll('[data-layout]').forEach((button) => button.addEventListener('click', () => setLayout(button.dataset.layout)));
    $('paperPicker').addEventListener('change', (event) => selectPaper(event.target.value));
    $('resetFilters').addEventListener('click', resetFilters);
    $('clusterSummary').addEventListener('click', scopeCluster);
  }

  function hydrateFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const selected = params.get('paper');
    if (selected && papers.some((paper) => paper.slug === selected)) selectedSlug = selected;
    const requestedLayout = params.get('layout');
    if (requestedLayout === 'cd') atlasLayout = 'cd';
    const scopedX = params.get('cx');
    const scopedY = params.get('cy');
    if (scopedX && scopedY) scopedCell = { layout: atlasLayout, x: scopedX, y: scopedY };
    const legacyTarget = params.get('target') ?? '';
    const legacyTargetParts = legacyTarget.split(':');
    const legacyTargetKind = legacyTargetParts[0];
    const legacyTargetValue = legacyTargetParts.slice(1).join(':');
    const values = {
      search: params.get('q') ?? '',
      familyFilter: params.get('a') ?? '',
      middleFilter: params.get('b') ?? '',
      objectFilter: params.get('c') ?? '',
      rewriteFilter: params.get('d') ?? '',
      technologyFilter: params.get('tech') ?? (legacyTargetKind === 'technology' ? legacyTargetValue : ''),
      workloadFilter: params.get('workload') ?? (legacyTargetKind === 'workload' ? legacyTargetValue : '')
    };
    Object.entries(values).forEach(([id, value]) => {
      const el = $(id);
      if (!el) return;
      el.value = value;
      if (el.value !== value) el.value = '';
    });
  }

  function updateUrlState() {
    const params = new URLSearchParams();
    if (atlasLayout === 'cd') params.set('layout', 'cd');
    const q = $('search').value.trim();
    if (q) params.set('q', q);
    if ($('familyFilter').value) params.set('a', $('familyFilter').value);
    if ($('middleFilter').value) params.set('b', $('middleFilter').value);
    if ($('objectFilter').value) params.set('c', $('objectFilter').value);
    if ($('rewriteFilter').value) params.set('d', $('rewriteFilter').value);
    if ($('technologyFilter').value) params.set('tech', $('technologyFilter').value);
    if ($('workloadFilter').value) params.set('workload', $('workloadFilter').value);
    if (scopedCell?.layout === atlasLayout) {
      params.set('cx', scopedCell.x);
      params.set('cy', scopedCell.y);
    }
    if (selectedSlug) params.set('paper', selectedSlug);
    const query = params.toString();
    const next = `${window.location.pathname}${query ? `?${query}` : ''}${window.location.hash}`;
    window.history.replaceState(null, '', next);
  }

  function applyFilters({ syncUrl = true } = {}) {
    const q = $('search').value.trim().toLowerCase();
    const family = $('familyFilter').value;
    const middle = $('middleFilter').value;
    const objectCategory = $('objectFilter').value;
    const rewriteCategory = $('rewriteFilter').value;
    const technology = $('technologyFilter').value;
    const workload = $('workloadFilter').value;
    filtered = papers.filter((paper) => {
      const familyMatch = !family || roles(paper).includes(family);
      const middleMatch = !middle || (paper.axis_B ?? []).includes(middle);
      const objectMatch = !objectCategory || (paper.axis_C_object_vocab ?? []).includes(objectCategory);
      const rewriteMatch = !rewriteCategory || (paper.axis_D_rewrite_types ?? []).includes(rewriteCategory);
      const technologyMatch = !technology || (paper.technology ?? []).includes(technology);
      const workloadMatch = !workload || (paper.workloads ?? []).includes(workload);
      const searchMatch = !q || textBlob(paper).includes(q);
      const cluster = clusterForPaper(paper);
      const cellMatch = !scopedCell || scopedCell.layout !== atlasLayout || (cluster.x === scopedCell.x && cluster.y === scopedCell.y);
      return familyMatch && middleMatch && objectMatch && rewriteMatch && technologyMatch && workloadMatch && searchMatch && cellMatch;
    });
    if (!filtered.some((p) => p.slug === selectedSlug)) selectedSlug = filtered[0]?.slug ?? null;
    if (!filtered.some((p) => p.slug === hoveredSlug)) hoveredSlug = null;
    if (syncUrl) updateUrlState();
    renderAll();
  }

  function resetFilters() {
    $('search').value = '';
    $('familyFilter').value = '';
    $('middleFilter').value = '';
    $('objectFilter').value = '';
    $('rewriteFilter').value = '';
    $('technologyFilter').value = '';
    $('workloadFilter').value = '';
    filtered = [...papers];
    if (!filtered.some((p) => p.slug === selectedSlug)) selectedSlug = filtered[0]?.slug ?? papers[0]?.slug ?? null;
    hoveredSlug = null;
    scopedCell = null;
    updateUrlState();
    renderAll();
  }

  function scopeCluster(event) {
    const button = event.target.closest('[data-scope-x]');
    if (!button) return;
    if (atlasLayout === 'cd') {
      $('objectFilter').value = button.dataset.scopeX ?? '';
      $('rewriteFilter').value = button.dataset.scopeY ?? '';
    } else {
      $('familyFilter').value = button.dataset.scopeX ?? '';
      $('middleFilter').value = button.dataset.scopeY ?? '';
    }
    scopedCell = {
      layout: atlasLayout,
      x: button.dataset.scopeX ?? '',
      y: button.dataset.scopeY ?? ''
    };
    applyFilters();
  }

  function xForFamily(code) {
    const { xLeft: left, xRight: right } = atlasProfile();
    const i = Math.max(0, familyCodes.indexOf(code));
    return left + (right - left) * (i / Math.max(1, familyCodes.length - 1));
  }

  function yForMiddle(code) {
    const { yTop: top, yBottom: bottom } = atlasProfile();
    const i = Math.max(0, middleCodes.indexOf(code));
    return top + (bottom - top) * (i / Math.max(1, middleCodes.length - 1));
  }

  function xForObject(category) {
    const { xLeft: left, xRight: right } = atlasProfile();
    const i = Math.max(0, objectCategories.indexOf(category));
    return left + (right - left) * (i / Math.max(1, objectCategories.length - 1));
  }

  function yForRewrite(category) {
    const { yTop: top, yBottom: bottom } = atlasProfile();
    const i = Math.max(0, rewriteCategories.indexOf(category));
    return top + (bottom - top) * (i / Math.max(1, rewriteCategories.length - 1));
  }

  function shortCategory(label) {
    return label
      .replace('hardware template / macro choice', 'template')
      .replace('operator graph transformation', 'graph')
      .replace('loop or tensor-schedule transformation', 'loop/tensor')
      .replace('mapping, placement, tiling, or allocation', 'mapping')
      .replace('mode selection across compute, memory, or device classes', 'mode')
      .replace('instruction, microprogram, or trace generation', 'instruction')
      .replace('numeric format, precision, quantization, or approximation', 'numeric')
      .replace('runtime scheduling, placement, batching, or data movement', 'runtime')
      .replace('fault, variation, calibration, or accuracy handling', 'accuracy')
      .replace('benchmark, API, or workload-porting pattern', 'benchmark')
      .replace('ADC / DAC / peripherals', 'ADC/DAC')
      .replace('nonideality / faults', 'nonideality')
      .replace('loop / tensor schedule', 'loop/tensor')
      .replace('chip / emulator address', 'address')
      .replace('memory service properties', 'mem service')
      .replace('Uncategorized object', 'uncat.')
      .replace('Uncategorized rewrite', 'uncat.');
  }

  function taxonomyFootprint(paper) {
    const axisRoles = [...new Set(roles(paper).filter((code) => families[code]))];
    const styles = [...new Set((paper.axis_B ?? []).filter((code) => middles[code]))];
    return axisRoles.flatMap((family) => styles.map((middle) => ({
      family,
      middle,
      x: xForFamily(family),
      y: yForMiddle(middle)
    })));
  }

  function objectRewriteFootprint(paper) {
    const objects = [...new Set((paper.axis_C_object_vocab ?? []).filter((category) => objectCategories.includes(category)))];
    const rewrites = [...new Set((paper.axis_D_rewrite_types ?? []).filter((category) => rewriteCategories.includes(category)))];
    return objects.flatMap((objectCategory) => rewrites.map((rewriteCategory) => ({
      objectCategory,
      rewriteCategory,
      x: xForObject(objectCategory),
      y: yForRewrite(rewriteCategory)
    })));
  }

  function drawHoveredFootprint(svg) {
    const paper = hoveredPaper();
    if (!paper) return;
    const points = atlasLayout === 'cd' ? objectRewriteFootprint(paper) : taxonomyFootprint(paper);
    if (!points.length) return;
    const color = families[paper.axis_A.primary]?.color ?? '#335cff';
    const group = node('g', { class: 'taxonomy-footprint', 'aria-hidden': 'true', 'pointer-events': 'none' });

    const byRow = new Map();
    const byColumn = new Map();
    points.forEach((point) => {
      if (!byRow.has(point.y)) byRow.set(point.y, []);
      if (!byColumn.has(point.x)) byColumn.set(point.x, []);
      byRow.get(point.y).push(point);
      byColumn.get(point.x).push(point);
    });
    byRow.forEach((row) => {
      if (row.length < 2) return;
      row.sort((a, b) => a.x - b.x);
      group.append(node('line', { x1: row[0].x, y1: row[0].y, x2: row[row.length - 1].x, y2: row[0].y, stroke: color, 'stroke-width': 34, opacity: 0.16, 'stroke-linecap': 'round' }));
    });
    byColumn.forEach((column) => {
      if (column.length < 2) return;
      column.sort((a, b) => a.y - b.y);
      group.append(node('line', { x1: column[0].x, y1: column[0].y, x2: column[0].x, y2: column[column.length - 1].y, stroke: color, 'stroke-width': 34, opacity: 0.16, 'stroke-linecap': 'round' }));
    });

    points.forEach((point) => {
      group.append(node('rect', { x: point.x - 40, y: point.y - 28, width: 80, height: 56, rx: 16, fill: color, opacity: 0.18 }));
    });
    svg.append(group);
  }

  function drawAtlas() {
    const svg = $('atlas');
    const profile = atlasProfile();
    clear(svg);
    currentNodeHits = [];
    svg.setAttribute('viewBox', `0 0 ${profile.width} ${profile.height}`);
    svg.append(node('rect', { x: 0, y: 0, width: profile.width, height: profile.height, rx: 16, fill: '#fbfcff' }));
    if (atlasLayout === 'cd') {
      objectCategories.forEach((category, index) => {
        const x = xForObject(category);
        const label = shortCategory(category);
        const labelY = profile.xLabelY + (index % 2) * 34;
        svg.append(node('line', { x1: x, y1: profile.gridTop, x2: x, y2: profile.gridBottom, stroke: '#dce4ef', 'stroke-width': 1 }));
        appendText(svg, { x, y: labelY, 'text-anchor': 'middle', 'font-size': profile.fontLabel, 'font-weight': 900, fill: '#24364f' }, label, splitLabel(label, 10), 12);
      });
      rewriteCategories.forEach((category) => {
        const y = yForRewrite(category);
        svg.append(node('line', { x1: profile.gridLeft, y1: y, x2: profile.gridRight, y2: y, stroke: '#dce4ef', 'stroke-width': 1 }));
        appendText(svg, { x: profile.yLabelX, y: y + 5, 'font-size': profile.fontCode, 'font-weight': 900, fill: '#24364f' }, shortCategory(category));
      });
    } else {
      familyCodes.forEach((code) => {
        const x = xForFamily(code);
        svg.append(node('line', { x1: x, y1: profile.gridTop, x2: x, y2: profile.gridBottom, stroke: '#dce4ef', 'stroke-width': 1 }));
        appendText(svg, { x, y: profile.xLabelY, 'text-anchor': 'middle', 'font-size': profile.fontCode, 'font-weight': 900, fill: '#24364f' }, code);
        appendText(svg, { x, y: profile.xSubLabelY, 'text-anchor': 'middle', 'font-size': profile.fontLabel, fill: '#607086' }, families[code].short);
      });
      middleCodes.forEach((code) => {
        const y = yForMiddle(code);
        svg.append(node('line', { x1: profile.gridLeft, y1: y, x2: profile.gridRight, y2: y, stroke: '#dce4ef', 'stroke-width': 1 }));
        appendText(svg, { x: profile.yCodeX, y: y - 8, 'text-anchor': 'middle', 'font-size': profile.fontCode, 'font-weight': 900, fill: '#24364f' }, code);
        appendText(svg, { x: profile.yLabelX, y: y + 11, 'text-anchor': 'middle', 'font-size': profile.fontLabel, fill: '#607086' }, middles[code].short, splitLabel(middles[code].short, 12), 12);
      });
    }
    if (!filtered.length) {
      appendText(svg, { x: profile.width / 2, y: profile.height / 2, 'text-anchor': 'middle', fill: '#607086', 'font-size': 18 }, 'No papers match the current filters.');
      return;
    }
    drawHoveredFootprint(svg);
    const offsets = groupedPositions(filtered);
    filtered.forEach((paper) => {
      const baseX = atlasLayout === 'cd' ? xForObject(paper.axis_C_object_vocab?.[0]) : xForFamily(paper.axis_A.primary);
      const baseY = atlasLayout === 'cd' ? yForRewrite(paper.axis_D_rewrite_types?.[0]) : yForMiddle(firstMiddle(paper));
      const offset = offsets.get(paper.slug) ?? { dx: 0, dy: 0 };
      const x = Math.max(profile.gridLeft + 18, Math.min(profile.gridRight - 18, baseX + offset.dx));
      const y = Math.max(profile.gridTop + 18, Math.min(profile.gridBottom - 18, baseY + offset.dy));
      const isSelected = paper.slug === selectedSlug;
      const isHovered = paper.slug === hoveredSlug;
      const r = isHovered ? profile.hoverR : profile.nodeR;
      const color = families[paper.axis_A.primary]?.color ?? '#335cff';
      const className = [
        'atlas-node',
        isHovered ? 'is-hovered' : 'is-muted',
        isSelected ? 'is-clicked' : ''
      ].filter(Boolean).join(' ');
      const g = node('g', { class: className, tabindex: 0, role: 'button', 'aria-label': `Select ${paper.title}`, style: 'cursor:pointer' });
      if (isSelected) {
        g.append(node('circle', { class: 'clicked-ring', cx: x, cy: y, r: isHovered ? r + 11 : r + 9, fill: 'none', stroke: '#111a33', 'stroke-width': isHovered ? 2.75 : 2.25, 'stroke-dasharray': '5 4', opacity: isHovered ? 0.78 : 0.86 }));
      }
      g.append(node('circle', { cx: x, cy: y, r: r + 6, fill: color, opacity: isHovered ? 0.2 : isSelected ? 0.12 : 0.035 }));
      g.append(node('circle', { cx: x, cy: y, r, fill: color, opacity: isHovered ? 0.95 : isSelected ? 0.56 : 0.34, stroke: isHovered ? '#111a33' : isSelected ? color : '#ffffff', 'stroke-width': isHovered ? 3 : isSelected ? 2.25 : 1.25 }));
      appendText(g, { x, y: y + 4, 'text-anchor': 'middle', 'font-size': isHovered ? profile.hoverFont : profile.nodeFont, 'font-weight': 900, fill: isHovered ? '#fff' : '#f4f7fb', opacity: isHovered ? 1 : isSelected ? 0.9 : 0.72, 'pointer-events': 'none' }, initials(paper));
      g.addEventListener('click', () => selectPaper(paper.slug));
      g.addEventListener('mousemove', (event) => showTooltip(event, paper));
      g.addEventListener('mouseenter', (event) => {
        setHoveredPaper(paper.slug);
        showTooltip(event, paper);
      });
      g.addEventListener('mouseleave', () => {
        clearHoveredPaper(paper.slug);
        hideTooltip();
      });
      g.addEventListener('focus', () => {
        setHoveredPaper(paper.slug);
        showTooltipForNode(g, paper);
      });
      g.addEventListener('blur', () => {
        clearHoveredPaper(paper.slug);
        hideTooltip();
      });
      g.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          selectPaper(paper.slug);
        }
      });
      svg.append(g);
      currentNodeHits.push({ slug: paper.slug, x, y, radius: r + 10 });
    });
  }

  function setupAtlasPointerTracking() {
    const svg = $('atlas');
    svg.addEventListener('pointermove', (event) => {
      const point = svg.createSVGPoint();
      point.x = event.clientX;
      point.y = event.clientY;
      const matrix = svg.getScreenCTM();
      if (!matrix) return;
      const svgPoint = point.matrixTransform(matrix.inverse());
      const hit = hitTestAtlasNode(svgPoint.x, svgPoint.y);
      if (hit) setHoveredPaper(hit.slug);
      else clearHoveredPaper();
    });
    svg.addEventListener('click', (event) => {
      const point = svg.createSVGPoint();
      point.x = event.clientX;
      point.y = event.clientY;
      const matrix = svg.getScreenCTM();
      if (!matrix) return;
      const svgPoint = point.matrixTransform(matrix.inverse());
      const hit = hitTestAtlasNode(svgPoint.x, svgPoint.y);
      if (hit) selectPaper(hit.slug);
    });
    svg.addEventListener('pointerleave', () => {
      clearHoveredPaper();
      hideTooltip();
    });
  }

  function hitTestAtlasNode(x, y) {
    return [...currentNodeHits].reverse().find((candidate) => {
      const dx = x - candidate.x;
      const dy = y - candidate.y;
      return Math.hypot(dx, dy) <= candidate.radius;
    });
  }

  function tooltipHtml(paper) {
    return `
      <b>${esc(paperLabel(paper))}</b>
      ${metadataLine(paper) ? `<span>${esc(metadataLine(paper))}</span>` : ''}
      <span>${atlasLayout === 'cd'
        ? `${esc(paper.axis_C_object_vocab?.[0] ?? '')} · ${esc(paper.axis_D_rewrite_types?.[0] ?? '')}`
        : `${esc(paper.axis_A.primary)} ${esc(families[paper.axis_A.primary]?.short ?? '')} · ${esc(firstMiddle(paper))} ${esc(middles[firstMiddle(paper)]?.short ?? '')}`}</span>
      <p>${inlineMarkdown(paper.summary)}</p>
    `;
  }

  function placeTooltip(x, y) {
    const tip = $('atlasTooltip');
    const pad = 18;
    const box = tip.getBoundingClientRect();
    const left = Math.min(window.innerWidth - box.width - pad, x + 18);
    const top = Math.min(window.innerHeight - box.height - pad, y + 18);
    tip.style.left = `${Math.max(pad, left)}px`;
    tip.style.top = `${Math.max(pad, top)}px`;
  }

  function showTooltip(event, paper) {
    activeTooltipPaper = paper;
    const tip = $('atlasTooltip');
    tip.innerHTML = tooltipHtml(paper);
    tip.setAttribute('aria-hidden', 'false');
    tip.classList.add('visible');
    placeTooltip(event.clientX, event.clientY);
  }

  function showTooltipForNode(target, paper) {
    activeTooltipPaper = paper;
    const rect = target.getBoundingClientRect();
    const tip = $('atlasTooltip');
    tip.innerHTML = tooltipHtml(paper);
    tip.setAttribute('aria-hidden', 'false');
    tip.classList.add('visible');
    placeTooltip(rect.left + rect.width / 2, rect.top + rect.height / 2);
  }

  function hideTooltip() {
    activeTooltipPaper = null;
    const tip = $('atlasTooltip');
    tip.classList.remove('visible');
    tip.setAttribute('aria-hidden', 'true');
  }

  function renderLegend() {
    $('familyLegend').innerHTML = familyCodes.map((code) => `<span class="legend-item"><span class="swatch" style="background:${families[code].color}"></span>${code} ${esc(families[code].short)}</span>`).join('');
  }

  function renderStats() {
    const xCodes = atlasLayout === 'cd' ? objectCategories : familyCodes;
    const yCodes = atlasLayout === 'cd' ? rewriteCategories : middleCodes;
    const xCounts = Object.fromEntries(xCodes.map((code) => [code, filtered.filter((p) => atlasLayout === 'cd' ? (p.axis_C_object_vocab ?? []).includes(code) : p.axis_A.primary === code).length]));
    const topX = Object.entries(xCounts).sort((a, b) => b[1] - a[1])[0];
    const yCounts = Object.fromEntries(yCodes.map((code) => [code, filtered.filter((p) => atlasLayout === 'cd' ? (p.axis_D_rewrite_types ?? []).includes(code) : (p.axis_B ?? []).includes(code)).length]));
    const topY = Object.entries(yCounts).sort((a, b) => b[1] - a[1])[0];
    const filterCount = ['search', 'familyFilter', 'middleFilter', 'objectFilter', 'rewriteFilter', 'technologyFilter', 'workloadFilter'].filter((id) => $(id).value).length;
    $('filteredStats').innerHTML = [
      ['Papers', filtered.length],
      [atlasLayout === 'cd' ? 'Top Axis C' : 'Top Axis A', topX ? `${shortCategory(topX[0])} (${topX[1]})` : '—'],
      [atlasLayout === 'cd' ? 'Top Axis D' : 'Top Axis B', topY ? `${shortCategory(topY[0])} (${topY[1]})` : '—'],
      ['Filters', filterCount]
    ].map(([label, value]) => `<div class="mini-stat"><strong>${esc(value)}</strong><span>${esc(label)}</span></div>`).join('');
  }

  function clusterForPaper(paper) {
    if (atlasLayout === 'cd') {
      const x = paper.axis_C_object_vocab?.[0] ?? 'Uncategorized object';
      const y = paper.axis_D_rewrite_types?.[0] ?? 'Uncategorized rewrite';
      return {
        x,
        y,
        label: `${shortCategory(x)} x ${shortCategory(y)}`
      };
    }
    const x = paper.axis_A.primary;
    const y = firstMiddle(paper);
    return {
      x,
      y,
      label: `${x} ${families[x]?.short ?? x} x ${y} ${middles[y]?.short ?? y}`
    };
  }

  function renderClusterSummary() {
    const container = $('clusterSummary');
    if (!filtered.length) {
      container.innerHTML = '';
      return;
    }
    const groups = new Map();
    filtered.forEach((paper) => {
      const cluster = clusterForPaper(paper);
      const key = `${cluster.x}:::${cluster.y}`;
      if (!groups.has(key)) groups.set(key, { ...cluster, papers: [] });
      groups.get(key).papers.push(paper);
    });
    const denseClusters = [...groups.values()]
      .sort((a, b) => b.papers.length - a.papers.length || a.label.localeCompare(b.label))
      .slice(0, 4);

    container.innerHTML = `
      <div class="cluster-head">
        <h3>Dense cells in this view</h3>
        <span>${esc(filtered.length)} paper${filtered.length === 1 ? '' : 's'} across ${esc(groups.size)} cell${groups.size === 1 ? '' : 's'}</span>
      </div>
      <div class="cluster-grid">
        ${denseClusters.map((cluster) => {
          const examples = cluster.papers
            .slice()
            .sort((a, b) => a.title.localeCompare(b.title))
            .slice(0, 3)
            .map((paper) => `<li>${esc(shortTitle(paper))}</li>`)
            .join('');
          return `
            <article class="cluster-card">
              <div>
                <b>${esc(cluster.label)}</b>
                <span>${cluster.papers.length} paper${cluster.papers.length === 1 ? '' : 's'}</span>
              </div>
              <ul>${examples}</ul>
              <button type="button" class="secondary" data-scope-x="${esc(cluster.x)}" data-scope-y="${esc(cluster.y)}">Scope cell</button>
            </article>
          `;
        }).join('')}
      </div>
    `;
  }

  function renderPicker() {
    const picker = $('paperPicker');
    picker.disabled = filtered.length === 0;
    picker.innerHTML = filtered.length
      ? filtered.map((paper) => `<option value="${esc(paper.slug)}"${paper.slug === selectedSlug ? ' selected' : ''}>${esc(shortTitle(paper))} — ${esc(paper.title)}</option>`).join('')
      : '<option>No matching papers</option>';
  }

  function selectPaper(slug) {
    selectedSlug = slug;
    hideTooltip();
    updateUrlState();
    renderAll();
  }

  function setHoveredPaper(slug) {
    if (hoveredSlug === slug) return;
    hoveredSlug = slug;
    drawAtlas();
  }

  function clearHoveredPaper(slug = null) {
    if (!hoveredSlug || (slug && hoveredSlug !== slug)) return;
    hoveredSlug = null;
    drawAtlas();
  }

  function setLayout(layout) {
    atlasLayout = layout === 'cd' ? 'cd' : 'ab';
    if (scopedCell?.layout !== atlasLayout) scopedCell = null;
    document.querySelectorAll('[data-layout]').forEach((button) => {
      const isActive = button.dataset.layout === atlasLayout;
      button.setAttribute('aria-pressed', String(isActive));
      button.classList.toggle('is-active', isActive);
    });
    updateUrlState();
    renderAll();
  }

  function selectedPaper() {
    return papers.find((p) => p.slug === selectedSlug) ?? filtered[0] ?? null;
  }

  function hoveredPaper() {
    return papers.find((p) => p.slug === hoveredSlug) ?? null;
  }

  function renderDetails() {
    const paper = selectedPaper();
    if (!paper) {
      $('workDetails').classList.add('empty');
      $('workDetails').innerHTML = papers.length
        ? '<div class="empty">No papers match the current filters.</div>'
        : '<div class="empty">Add Markdown files in <code>src/content/papers</code> to populate the atlas.</div>';
      $('workMore').innerHTML = '';
      return;
    }
    $('workDetails').classList.remove('empty');
    $('workDetails').innerHTML = `
      <div class="work-title">
        <div>
          <h3>${esc(paper.title)}</h3>
          <div class="subtle">${esc(metadataLine(paper) || paper.subtitle || 'No venue/year in metadata')}</div>
        </div>
      </div>
      <p class="subtle atlas-summary" style="margin:0">${inlineMarkdown(paper.summary)}</p>
      <div class="atlas-fact-list">
        <div><span>Stack view</span><strong>${esc(axisLabel(paper))}</strong></div>
        <div><span>Object view</span><strong>${esc(objectRewriteLabel(paper))}</strong></div>
      </div>
      <p style="margin:0"><a class="badge" href="${detailHref(paper)}">Open paper page</a></p>
    `;
    renderReadingBridge(paper);
  }

  function renderReadingBridge(paper) {
    if (!paper) {
      $('workMore').innerHTML = '';
      return;
    }
    $('workMore').innerHTML = `
      <div class="reading-bridge" aria-label="Selected paper reading bridge">
        <section class="bridge-section">
          <h4>Read for</h4>
          <ul>
            ${bridgeBullets(paper).map((item) => `<li>${inlineMarkdown(item)}</li>`).join('')}
          </ul>
        </section>
        <section class="bridge-section">
          <h4>Objects the atlas can compare</h4>
          <div class="cloud-nodes">
            ${chips(paper.axis_C_object_vocab, 'object', 3)}
            ${chips(paper.axis_D_rewrite_types, 'rewrite', 3)}
          </div>
        </section>
        <section class="bridge-section">
          <h4>Context filters</h4>
          <div class="cloud-nodes">
            ${chips([...(paper.technology ?? []), ...(paper.workloads ?? [])], 'context', 5)}
          </div>
        </section>
        <p class="bridge-note">Full source, artifact, and frontmatter details stay on the paper page.</p>
      </div>
    `;
  }

  function renderAll() {
    renderLegend();
    drawAtlas();
    renderStats();
    renderPicker();
    renderDetails();
    renderClusterSummary();
    if (activeTooltipPaper) hideTooltip();
  }

  setupFilters();
  setupAtlasPointerTracking();
  hydrateFromUrl();
  setLayout(atlasLayout);
  applyFilters();
})();
</script>
