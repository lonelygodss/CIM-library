---
type AxisA = 'A1' | 'A2' | 'A3' | 'A4' | 'A5' | 'A6';
type AxisB = 'B1' | 'B2' | 'B3' | 'B4' | 'B5' | 'B6' | 'B7';

type Family = {
  name: string;
  short: string;
  artifact: string;
  color: string;
};

type Middle = {
  name: string;
  short: string;
  desc: string;
};

type Paper = {
  slug: string;
  title: string;
  subtitle?: string | null;
  year?: number | null;
  venue?: string | null;
  summary: string;
  tags?: string[];
  technology?: string[];
  workloads?: string[];
  baselines?: string[];
  axis_A: {
    primary: AxisA;
    secondary?: AxisA[];
  };
  axis_B: AxisB[];
  axis_C_first_class_objects?: string[];
  axis_D_rewrite_objects?: string[];
};

type Taxonomy = {
  families: Record<AxisA, Family>;
  middles: Record<AxisB, Middle>;
};

interface Props {
  papers: Paper[];
  taxonomy: Taxonomy;
}

const { papers, taxonomy } = Astro.props;
---
<section id="atlas-section" class="panel pad">
  <div class="section-title">
    <div>
      <h2>Interactive paper atlas</h2>
      <div class="subtle">Each circle is a paper. Horizontal position is primary Axis A; vertical position is the first listed Axis B. Hover or focus for a quick read; select a node to inspect its metadata cloud.</div>
    </div>
    <div class="atlas-count" id="filteredStats" aria-live="polite"></div>
  </div>
  <div class="controls" aria-label="Taxonomy filters">
    <input id="search" type="search" placeholder="Search paper, target, abstraction, object, evidence..." aria-label="Search papers" />
    <select id="familyFilter" aria-label="Filter by stack role"></select>
    <select id="middleFilter" aria-label="Filter by middle-layer style"></select>
    <select id="targetFilter" aria-label="Filter by technology or workload"></select>
  </div>
  <div class="viz-grid">
    <div class="panel viz-card atlas-box">
      <svg id="atlas" viewBox="0 0 1320 760" role="img" aria-label="CIM taxonomy atlas"></svg>
      <div class="legend" id="familyLegend"></div>
    </div>
    <aside class="panel viz-card selected-panel" aria-live="polite">
      <div id="workDetails" class="empty">Select a paper.</div>
      <div id="workMore"></div>
    </aside>
  </div>
  <div id="atlasTooltip" class="atlas-tooltip" role="status" aria-hidden="true"></div>
</section>

<section id="taxonomy" class="panel pad taxonomy-support">
  <div class="section-title">
    <div>
      <h2>Taxonomy axes</h2>
      <div class="subtle">Technology such as SRAM, RRAM, DRAM-PIM, CAM, or UPMEM is metadata; the atlas is organized by stack artifact and abstraction style.</div>
    </div>
  </div>
  <div class="axis-explainer">
    <div>
      <h3>Axis A — stack role</h3>
      <div class="axis-list">
        {Object.entries(taxonomy.families).map(([code, family]) => (
          <div class="axis-row">
            <code>{code}</code>
            <span><b>{family.name}</b>{family.artifact}</span>
          </div>
        ))}
      </div>
    </div>
    <div>
      <h3>Axis B — middle-layer style</h3>
      <div class="axis-list">
        {Object.entries(taxonomy.middles).map(([code, middle]) => (
          <div class="axis-row">
            <code>{code}</code>
            <span><b>{middle.name}</b>{middle.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline type="application/json" id="paper-data" set:html={JSON.stringify(papers)}></script>
<script is:inline type="application/json" id="taxonomy-data" set:html={JSON.stringify(taxonomy)}></script>
<script is:inline>
(() => {
  const papers = JSON.parse(document.getElementById('paper-data').textContent);
  const taxonomy = JSON.parse(document.getElementById('taxonomy-data').textContent);
  const families = taxonomy.families;
  const middles = taxonomy.middles;
  const familyCodes = Object.keys(families);
  const middleCodes = Object.keys(middles);
  const svgNS = 'http://www.w3.org/2000/svg';
  let selectedSlug = papers[0]?.slug ?? null;
  let filtered = [...papers];
  let activeTooltipPaper = null;

  const $ = (id) => document.getElementById(id);
  const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[m]));
  const firstMiddle = (paper) => paper.axis_B?.[0] ?? 'B1';
  const roles = (paper) => [paper.axis_A.primary, ...(paper.axis_A.secondary ?? [])];
  const metadataLine = (paper) => [paper.year, paper.venue].filter(Boolean).join(' · ');
  const paperLabel = (paper) => paper.subtitle?.replace(/^Scoped CIM stack note( seed)?$/i, '')?.trim() || paper.title;
  const shortTitle = (paper) => paper.title
    .replace(/^([^:—-]{2,42})[:—-].*$/, '$1')
    .replace(/\b(a|an|the|for|with|and|of|to|in)\b/gi, '')
    .trim()
    .split(/\s+/)
    .slice(0, 3)
    .join(' ') || paper.title.slice(0, 18);
  const initials = (paper) => shortTitle(paper).split(/[\s/-]+/).filter(Boolean).slice(0, 3).map((x) => x[0]).join('').toUpperCase();
  const textBlob = (paper) => [
    paper.title,
    paper.subtitle,
    paper.summary,
    ...(paper.tags ?? []),
    ...(paper.technology ?? []),
    ...(paper.workloads ?? []),
    ...(paper.baselines ?? []),
    ...(paper.axis_C_first_class_objects ?? []),
    ...(paper.axis_D_rewrite_objects ?? [])
  ].join(' ').toLowerCase();
  const clear = (node) => { while (node.firstChild) node.removeChild(node.firstChild); };
  const node = (name, attrs = {}, text = '') => {
    const el = document.createElementNS(svgNS, name);
    Object.entries(attrs).forEach(([key, value]) => el.setAttribute(key, value));
    if (text) el.textContent = text;
    return el;
  };
  const category = (label, items, cls, limit = 8) => `
    <section class="cloud-group">
      <h4>${esc(label)}</h4>
      <div class="cloud-nodes">
        ${(items ?? []).filter(Boolean).slice(0, limit).map((item) => `<span class="cloud-node ${cls}">${esc(item)}</span>`).join('')}
        ${(items ?? []).filter(Boolean).length > limit ? `<span class="cloud-node more">+${(items ?? []).length - limit}</span>` : ''}
      </div>
    </section>
  `;

  function cellKey(paper) {
    return `${paper.axis_A.primary}:${firstMiddle(paper)}`;
  }

  function groupedPositions(items) {
    const groups = new Map();
    items.forEach((paper) => {
      const key = cellKey(paper);
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key).push(paper);
    });
    const positions = new Map();
    groups.forEach((group) => {
      const sorted = [...group].sort((a, b) => a.title.localeCompare(b.title));
      const n = sorted.length;
      sorted.forEach((paper, index) => {
        const ring = Math.ceil(Math.sqrt(index + 1));
        const angle = (index * 2.399963229728653) % (Math.PI * 2);
        const scale = n > 10 ? 10 : 13;
        positions.set(paper.slug, {
          dx: Math.cos(angle) * ring * scale,
          dy: Math.sin(angle) * ring * scale
        });
      });
    });
    return positions;
  }
  function setupFilters() {
    const familyFilter = $('familyFilter');
    const middleFilter = $('middleFilter');
    const targetFilter = $('targetFilter');
    familyFilter.innerHTML = `<option value="">All Axis A roles</option>` + familyCodes.map((code) => `<option value="${code}">${code} — ${esc(families[code].short)}</option>`).join('');
    middleFilter.innerHTML = `<option value="">All Axis B styles</option>` + middleCodes.map((code) => `<option value="${code}">${code} — ${esc(middles[code].short)}</option>`).join('');
    const targets = [...new Set(papers.flatMap((p) => [...(p.technology ?? []), ...(p.workloads ?? [])]))].sort();
    targetFilter.innerHTML = `<option value="">All technologies/workloads</option>` + targets.map((tag) => `<option value="${esc(tag)}">${esc(tag)}</option>`).join('');
    ['search', 'familyFilter', 'middleFilter', 'targetFilter'].forEach((id) => $(id).addEventListener('input', applyFilters));
  }

  function applyFilters() {
    const q = $('search').value.trim().toLowerCase();
    const family = $('familyFilter').value;
    const middle = $('middleFilter').value;
    const target = $('targetFilter').value;
    filtered = papers.filter((paper) => {
      const familyMatch = !family || roles(paper).includes(family);
      const middleMatch = !middle || (paper.axis_B ?? []).includes(middle);
      const targetMatch = !target || [...(paper.technology ?? []), ...(paper.workloads ?? [])].includes(target);
      const searchMatch = !q || textBlob(paper).includes(q);
      return familyMatch && middleMatch && targetMatch && searchMatch;
    });
    if (!filtered.some((p) => p.slug === selectedSlug)) selectedSlug = filtered[0]?.slug ?? papers[0]?.slug ?? null;
    renderAll();
  }

  function xForFamily(code) {
    const left = 160;
    const right = 1230;
    const i = Math.max(0, familyCodes.indexOf(code));
    return left + (right - left) * (i / Math.max(1, familyCodes.length - 1));
  }

  function yForMiddle(code) {
    const top = 100;
    const bottom = 665;
    const i = Math.max(0, middleCodes.indexOf(code));
    return top + (bottom - top) * (i / Math.max(1, middleCodes.length - 1));
  }

  function drawAtlas() {
    const svg = $('atlas');
    clear(svg);
    svg.append(node('rect', { x: 0, y: 0, width: 1320, height: 760, rx: 16, fill: '#fbfcff' }));
    familyCodes.forEach((code) => {
      const x = xForFamily(code);
      svg.append(node('line', { x1: x, y1: 70, x2: x, y2: 695, stroke: '#dce4ef', 'stroke-width': 1 }));
      svg.append(node('text', { x, y: 32, 'text-anchor': 'middle', 'font-size': 15, 'font-weight': 900, fill: '#24364f' }, code));
      svg.append(node('text', { x, y: 53, 'text-anchor': 'middle', 'font-size': 13, fill: '#607086' }, families[code].short));
    });
    middleCodes.forEach((code) => {
      const y = yForMiddle(code);
      svg.append(node('line', { x1: 104, y1: y, x2: 1268, y2: y, stroke: '#dce4ef', 'stroke-width': 1 }));
      svg.append(node('text', { x: 26, y: y + 5, 'font-size': 15, 'font-weight': 900, fill: '#24364f' }, code));
      svg.append(node('text', { x: 62, y: y + 5, 'font-size': 13, fill: '#607086' }, middles[code].short));
    });
    if (!filtered.length) {
      svg.append(node('text', { x: 660, y: 380, 'text-anchor': 'middle', fill: '#607086', 'font-size': 17 }, 'No papers match the current filters.'));
      return;
    }
    const offsets = groupedPositions(filtered);
    filtered.forEach((paper) => {
      const baseX = xForFamily(paper.axis_A.primary);
      const baseY = yForMiddle(firstMiddle(paper));
      const offset = offsets.get(paper.slug) ?? { dx: 0, dy: 0 };
      const x = Math.max(126, Math.min(1276, baseX + offset.dx));
      const y = Math.max(84, Math.min(702, baseY + offset.dy));
      const r = paper.slug === selectedSlug ? 17 : 12;
      const color = families[paper.axis_A.primary]?.color ?? '#335cff';
      const g = node('g', { tabindex: 0, role: 'button', 'aria-label': `Select ${paper.title}`, style: 'cursor:pointer' });
      g.append(node('circle', { cx: x, cy: y, r: r + 6, fill: color, opacity: paper.slug === selectedSlug ? 0.17 : 0.06 }));
      g.append(node('circle', { cx: x, cy: y, r, fill: color, opacity: paper.slug === selectedSlug ? 0.92 : 0.72, stroke: paper.slug === selectedSlug ? '#111a33' : '#ffffff', 'stroke-width': paper.slug === selectedSlug ? 3 : 1.5 }));
      g.append(node('text', { x, y: y + 4, 'text-anchor': 'middle', 'font-size': 10, 'font-weight': 900, fill: '#fff', 'pointer-events': 'none' }, initials(paper)));
      g.addEventListener('click', () => selectPaper(paper.slug));
      g.addEventListener('mousemove', (event) => showTooltip(event, paper));
      g.addEventListener('mouseenter', (event) => showTooltip(event, paper));
      g.addEventListener('mouseleave', hideTooltip);
      g.addEventListener('focus', () => showTooltipForNode(g, paper));
      g.addEventListener('blur', hideTooltip);
      g.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          selectPaper(paper.slug);
        }
      });
      svg.append(g);
    });
  }

  function tooltipHtml(paper) {
    return `
      <b>${esc(paperLabel(paper))}</b>
      ${metadataLine(paper) ? `<span>${esc(metadataLine(paper))}</span>` : ''}
      <span>${esc(paper.axis_A.primary)} ${esc(families[paper.axis_A.primary]?.short ?? '')} · ${esc(firstMiddle(paper))} ${esc(middles[firstMiddle(paper)]?.short ?? '')}</span>
      <p>${esc(paper.summary)}</p>
    `;
  }

  function placeTooltip(x, y) {
    const tip = $('atlasTooltip');
    const pad = 18;
    const box = tip.getBoundingClientRect();
    const left = Math.min(window.innerWidth - box.width - pad, x + 18);
    const top = Math.min(window.innerHeight - box.height - pad, y + 18);
    tip.style.left = `${Math.max(pad, left)}px`;
    tip.style.top = `${Math.max(pad, top)}px`;
  }

  function showTooltip(event, paper) {
    activeTooltipPaper = paper;
    const tip = $('atlasTooltip');
    tip.innerHTML = tooltipHtml(paper);
    tip.setAttribute('aria-hidden', 'false');
    tip.classList.add('visible');
    placeTooltip(event.clientX, event.clientY);
  }

  function showTooltipForNode(target, paper) {
    activeTooltipPaper = paper;
    const rect = target.getBoundingClientRect();
    const tip = $('atlasTooltip');
    tip.innerHTML = tooltipHtml(paper);
    tip.setAttribute('aria-hidden', 'false');
    tip.classList.add('visible');
    placeTooltip(rect.left + rect.width / 2, rect.top + rect.height / 2);
  }

  function hideTooltip() {
    activeTooltipPaper = null;
    const tip = $('atlasTooltip');
    tip.classList.remove('visible');
    tip.setAttribute('aria-hidden', 'true');
  }

  function renderLegend() {
    $('familyLegend').innerHTML = familyCodes.map((code) => `<span class="legend-item"><span class="swatch" style="background:${families[code].color}"></span>${code} ${esc(families[code].short)}</span>`).join('');
  }

  function renderStats() {
    const roleCounts = Object.fromEntries(familyCodes.map((code) => [code, filtered.filter((p) => p.axis_A.primary === code).length]));
    const topRole = Object.entries(roleCounts).sort((a, b) => b[1] - a[1])[0];
    const middleCounts = Object.fromEntries(middleCodes.map((code) => [code, filtered.filter((p) => (p.axis_B ?? []).includes(code)).length]));
    const topMiddle = Object.entries(middleCounts).sort((a, b) => b[1] - a[1])[0];
    $('filteredStats').innerHTML = [
      ['Papers', filtered.length],
      ['Top Axis A', topRole ? `${topRole[0]} (${topRole[1]})` : '—'],
      ['Top Axis B', topMiddle ? `${topMiddle[0]} (${topMiddle[1]})` : '—']
    ].map(([label, value]) => `<div class="mini-stat"><strong>${esc(value)}</strong><span>${esc(label)}</span></div>`).join('');
  }

  function selectPaper(slug) {
    selectedSlug = slug;
    hideTooltip();
    renderAll();
  }

  function currentPaper() {
    return papers.find((p) => p.slug === selectedSlug) ?? filtered[0] ?? papers[0];
  }

  function renderDetails() {
    const paper = currentPaper();
    if (!paper) {
      $('workDetails').innerHTML = '<div class="empty">Add Markdown files in <code>src/content/papers</code> to populate the atlas.</div>';
      $('workMore').innerHTML = '';
      return;
    }
    const color = families[paper.axis_A.primary]?.color ?? '#335cff';
    const allRoles = roles(paper).map((code) => `${code} ${families[code]?.short ?? ''}`);
    const styleLabels = (paper.axis_B ?? []).map((code) => `${code} ${middles[code]?.short ?? ''}`);
    const contextTerms = [...(paper.technology ?? []), ...(paper.workloads ?? [])];
    $('workDetails').innerHTML = `
      <div class="work-title">
        <div>
          <h3>${esc(paper.title)}</h3>
          <div class="subtle">${esc(metadataLine(paper) || paper.subtitle || 'No venue/year in metadata')}</div>
        </div>
        <span class="badge" style="border-color:${color}; color:${color};">${esc(paper.axis_A.primary)}</span>
      </div>
      <p class="subtle" style="margin:0">${esc(paper.summary)}</p>
      <div class="badges">
        ${(paper.tags ?? []).slice(0, 8).map((tag) => `<span class="badge">${esc(tag)}</span>`).join('')}
      </div>
      <p style="margin:0"><a class="badge" href="/papers/${esc(paper.slug)}/">Open paper page</a></p>
    `;
    $('workMore').innerHTML = `
      <div class="coverage-cloud" aria-label="Selected paper axis coverage cloud">
        <div class="cloud-center">
          <span>Selected paper</span>
          <strong>${esc(shortTitle(paper))}</strong>
        </div>
        ${category('Axis A roles', allRoles, 'role', 5)}
        ${category('Axis B styles', styleLabels, 'style', 7)}
        ${category('Axis C first-class objects', paper.axis_C_first_class_objects ?? [], 'object', 6)}
        ${category('Axis D rewrite objects', paper.axis_D_rewrite_objects ?? [], 'rewrite', 6)}
        ${contextTerms.length ? category('Technology / workloads', contextTerms, 'context', 6) : ''}
        <p class="cloud-note">Descriptive metadata cloud only; it is not a score or ranking.</p>
      </div>
    `;
  }

  function renderAll() {
    renderLegend();
    drawAtlas();
    renderStats();
    renderDetails();
    if (activeTooltipPaper) hideTooltip();
  }

  setupFilters();
  renderAll();
})();
</script>
